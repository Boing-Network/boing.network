---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
---

<Layout
  title="Page not found"
  description="The page you're looking for doesn't exist. Boing Network — Authentic L1 blockchain."
>
  <article class="page page-404">
    <div class="error-content">
      <span class="error-icon" aria-hidden="true"><Icon name="link" size={64} /></span>
      <h1>Page not found</h1>
      <p class="lead">The page you're looking for doesn't exist or has been moved.</p>
      <nav class="error-links" aria-label="Quick links">
        <a href="/" class="btn btn-primary">Home</a>
        <a href="/testnet" class="btn btn-secondary">Dashboard</a>
        <a href="/resources" class="btn btn-secondary">Resources</a>
        <a href="/docs" class="btn btn-secondary">Documentation</a>
      </nav>
    </div>
  </article>
</Layout>

<style>
  .page-404 {
    max-width: 560px;
    margin: 0 auto;
    padding: 4rem 2rem;
    text-align: center;
  }
  .error-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }
  .error-icon {
    color: var(--text-tertiary);
    opacity: 0.7;
  }
  .page-404 h1 {
    font-size: 1.75rem;
    color: var(--text-primary);
    margin: 0;
  }
  .page-404 .lead {
    color: var(--text-secondary);
    margin: 0 0 1.5rem;
  }
  .error-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }
  .error-links .btn {
    display: inline-block;
    padding: 0.5rem 1rem;
    border-radius: 6px;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.2s ease, box-shadow 0.2s ease;
  }
  .error-links .btn:focus-visible {
    outline: 2px solid var(--accent-teal);
    outline-offset: 2px;
  }
  .error-links .btn-primary {
    background: linear-gradient(135deg, var(--accent-teal), var(--accent-cyan));
    color: var(--bg-primary);
  }
  .error-links .btn-secondary {
    background: rgba(34, 211, 238, 0.15);
    color: var(--accent-teal);
    border: 1px solid rgba(34, 211, 238, 0.3);
  }
  .error-links .btn:hover {
    opacity: 0.9;
  }
</style>
