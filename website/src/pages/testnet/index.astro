---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Testnet Portal"
  description="Boing Network testnet: sign in or register. Access your developer, community, or operator hub."
>
  <article class="portal-page portal-entry">
    <script is:inline src="/portal-session.js"></script>
    <div class="portal-hero">
      <h1>Testnet Portal</h1>
      <p class="lead">
        Sign in to open your hub, or register as a <strong>developer</strong>, <strong>community user</strong>, or <strong>node operator</strong>. Each hub is separate — you’ll be directed there after sign-in or registration.
      </p>
      <div class="hero-ctas">
        <a href="/testnet/sign-in" class="btn btn-primary">Sign in</a>
        <a href="/testnet/register" class="btn btn-secondary">Register</a>
      </div>
    </div>

    <section class="section" id="register-options">
      <h2>Register for a hub</h2>
      <p class="muted">Choose one role. After registration you’re taken to that hub’s dashboard.</p>
      <div class="role-cards">
        <a href="/testnet/register/developer" class="role-card">
          <h3>Developer Hub</h3>
          <p>Build dApps, register contracts, qualify for grants and the dApp incentive pool.</p>
          <span class="card-arrow">Register as developer →</span>
        </a>
        <a href="/testnet/register/user" class="role-card">
          <h3>Community Hub</h3>
          <p>Use the faucet, complete quests, share feedback. Earn user rewards.</p>
          <span class="card-arrow">Register as user →</span>
        </a>
        <a href="/testnet/register/operator" class="role-card">
          <h3>Operator Hub</h3>
          <p>Run a node or miner, join the leaderboard, earn testnet BOING.</p>
          <span class="card-arrow">Register as operator →</span>
        </a>
      </div>
    </section>

    <section class="section">
      <p><a href="/">← Back to Boing Network</a></p>
    </section>
  </article>
</Layout>

<script>
  (function () {
    var session = window.BoingPortalSession && window.BoingPortalSession.getSession();
    if (!session) return;
    var path = window.BoingPortalSession ? window.BoingPortalSession.roleAppPath(session.role) : '/testnet';
    if (path && path !== '/testnet') {
      window.location.href = path;
      return;
    }
  })();
</script>

<style>
  .portal-page { max-width: 640px; margin: 0 auto; padding: 2rem; }
  .portal-entry .portal-hero { margin-bottom: 2rem; }
  .portal-hero h1 { color: var(--text-primary); margin-bottom: 0.5rem; }
  .lead { color: var(--text-secondary); font-size: 1.05rem; margin-bottom: 1rem; }
  .hero-ctas { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.25rem; }
  .hero-ctas .btn { padding: 0.6rem 1.2rem; font-size: 1rem; text-decoration: none; font-weight: 600; border-radius: 6px; display: inline-block; }
  .hero-ctas .btn-primary { background: linear-gradient(135deg, var(--accent-teal), var(--accent-cyan)); color: var(--bg-primary); }
  .hero-ctas .btn-secondary { background: rgba(34,211,238,0.15); color: var(--accent-teal); border: 1px solid rgba(34,211,238,0.3); }
  .hero-ctas .btn-secondary:hover { background: rgba(34,211,238,0.25); }
  .section { margin-top: 2rem; }
  .section h2 { font-size: 1.2rem; color: var(--text-primary); margin-bottom: 0.5rem; }
  .section p { color: var(--text-secondary); }
  .muted { color: var(--text-tertiary); font-size: 0.95rem; margin-bottom: 1rem; }
  .role-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; margin-top: 1rem; }
  .role-card {
    display: flex;
    flex-direction: column;
    padding: 1.25rem;
    background: rgba(30,41,59,0.35);
    border: 1px solid rgba(34,211,238,0.2);
    border-radius: 1rem;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
  }
  .role-card:hover { border-color: rgba(34,211,238,0.5); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(6,182,212,0.2); }
  .role-card h3 { font-size: 1.1rem; margin: 0 0 0.5rem; color: var(--text-primary); }
  .role-card p { font-size: 0.9rem; color: var(--text-secondary); margin: 0 0 0.75rem; line-height: 1.4; flex: 1; }
  .card-arrow { margin-top: auto; padding-top: 0.75rem; font-size: 0.85rem; color: var(--accent-teal); font-weight: 500; }
</style>
