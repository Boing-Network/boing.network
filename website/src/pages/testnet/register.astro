---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Register — Testnet Portal"
  description="Register for the Boing Network testnet portal as developer, user, or node operator."
>
  <article class="portal-page">
    <nav class="portal-nav">
      <a href="/testnet">Portal</a>
      <a href="/testnet/register" class="active">Register</a>
      <a href="/testnet/developers">Developers</a>
      <a href="/testnet/users">Users</a>
      <a href="/testnet/operators">Operators</a>
    </nav>

    <h1>Register for the testnet</h1>
    <p class="lead">
      Enter your testnet account ID (32-byte hex) and choose your role. Optionally add contact info so we can reach you for rewards and updates.
    </p>

    <form id="register-form" class="register-form">
      <label for="account-id">Account ID (32-byte hex, with or without 0x) *</label>
      <input id="account-id" name="account_id_hex" type="text" placeholder="0x..." maxlength="66" required />

      <fieldset class="role-fieldset">
        <legend>Role *</legend>
        <label class="radio-label"><input type="radio" name="role" value="developer" /> Developer</label>
        <label class="radio-label"><input type="radio" name="role" value="user" checked /> User</label>
        <label class="radio-label"><input type="radio" name="role" value="node_operator" /> Node operator</label>
      </fieldset>

      <label for="email">Email (optional)</label>
      <input id="email" name="email" type="email" placeholder="you@example.com" />

      <label for="discord">Discord handle (optional)</label>
      <input id="discord" name="discord_handle" type="text" placeholder="username#1234" />

      <div id="github-row" class="optional-row" style="display: none;">
        <label for="github">GitHub username (optional)</label>
        <input id="github" name="github_username" type="text" placeholder="octocat" />
      </div>

      <div id="node-row" class="optional-row" style="display: none;">
        <label for="node-multiaddr">Node multiaddr (optional)</label>
        <input id="node-multiaddr" name="node_multiaddr" type="text" placeholder="/ip4/1.2.3.4/tcp/4001" />
      </div>

      <button type="submit" id="submit-btn">Register</button>
      <p id="form-message" class="form-message" aria-live="polite"></p>
    </form>

    <section class="section">
      <p><a href="/testnet">← Back to portal</a></p>
    </section>
  </article>
</Layout>

<script>
  (function () {
    const form = document.getElementById('register-form');
    if (!form) return;

    const accountInput = form.querySelector('#account-id') as HTMLInputElement;
    const roleInputs = form.querySelectorAll('input[name="role"]') as NodeListOf<HTMLInputElement>;
    const githubRow = document.getElementById('github-row');
    const nodeRow = document.getElementById('node-row');
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const messageEl = document.getElementById('form-message') as HTMLParagraphElement;

    function setMessage(text: string, isError = false) {
      if (messageEl) {
        messageEl.textContent = text;
        messageEl.style.color = isError ? 'var(--error-color, #f87171)' : 'var(--text-secondary)';
      }
    }

    function toggleOptionalRows() {
      const role = Array.from(roleInputs).find((r) => r.checked)?.value;
      if (githubRow) githubRow.style.display = role === 'developer' ? 'block' : 'none';
      if (nodeRow) nodeRow.style.display = role === 'node_operator' ? 'block' : 'none';
    }

    roleInputs.forEach((r) => r.addEventListener('change', toggleOptionalRows));

    // Pre-fill role from query
    const params = new URLSearchParams(typeof window !== 'undefined' ? window.location.search : '');
    const roleParam = params.get('role');
    if (roleParam && ['developer', 'user', 'node_operator'].includes(roleParam)) {
      const r = form.querySelector(`input[name="role"][value="${roleParam}"]`) as HTMLInputElement;
      if (r) { r.checked = true; toggleOptionalRows(); }
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      let accountHex = (accountInput?.value || '').trim();
      const role = Array.from(roleInputs).find((r) => r.checked)?.value;
      const email = (form.querySelector('#email') as HTMLInputElement)?.value?.trim() || undefined;
      const discordHandle = (form.querySelector('#discord') as HTMLInputElement)?.value?.trim() || undefined;
      const githubUsername = (form.querySelector('#github') as HTMLInputElement)?.value?.trim() || undefined;
      const nodeMultiaddr = (form.querySelector('#node-multiaddr') as HTMLInputElement)?.value?.trim() || undefined;

      if (!accountHex) { setMessage('Please enter your account ID.', true); return; }
      if (!role) { setMessage('Please select a role.', true); return; }
      if (!accountHex.startsWith('0x')) accountHex = '0x' + accountHex;
      if (accountHex.length !== 66) {
        setMessage('Account ID must be 32 bytes (64 hex chars + 0x).', true);
        return;
      }

      if (submitBtn) submitBtn.disabled = true;
      setMessage('Submitting…');

      try {
        const res = await fetch('/api/portal/register', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            account_id_hex: accountHex,
            role,
            email: email || undefined,
            discord_handle: discordHandle || undefined,
            github_username: githubUsername || undefined,
            node_multiaddr: nodeMultiaddr || undefined,
          }),
        });
        const data = await res.json().catch(() => ({}));

        if (res.ok && data.ok) {
          setMessage('Registered. Go to your dashboard: ' + (role === 'developer' ? 'Developers' : role === 'node_operator' ? 'Operators' : 'Users') + '.');
          try { localStorage.setItem('boing_portal_account', accountHex); } catch (_) {}
          const dashPath = role === 'developer' ? '/testnet/developers' : role === 'node_operator' ? '/testnet/operators' : '/testnet/users';
          setTimeout(() => { window.location.href = dashPath; }, 1500);
        } else if (res.status === 404 || res.status === 502) {
          setMessage('API not available yet. Please try again later or submit in Discord.', true);
        } else {
          setMessage(data.message || data.error || 'Registration failed.', true);
        }
      } catch (err) {
        setMessage('Network error. Try again or submit in Discord.', true);
      } finally {
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  })();
</script>

<style>
  .portal-page { max-width: 560px; margin: 0 auto; padding: 2rem; }
  .portal-nav { display: flex; flex-wrap: wrap; gap: 0.5rem 1rem; margin-bottom: 2rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border-color); }
  .portal-nav a { color: var(--text-secondary); font-weight: 500; }
  .portal-nav a:hover, .portal-nav a.active { color: var(--accent-teal); }
  .lead { color: var(--text-secondary); margin-bottom: 1.5rem; }
  .register-form label { display: block; margin-top: 1rem; color: var(--text-secondary); font-size: 0.9rem; }
  .register-form input[type="text"],
  .register-form input[type="email"] {
    width: 100%; max-width: 400px; padding: 12px 16px; margin-top: 0.25rem;
    font-family: var(--font-mono); font-size: 0.9rem; border: 1px solid var(--border-color);
    border-radius: 8px; background: var(--bg-tertiary); color: var(--text-primary);
  }
  .role-fieldset { margin-top: 1.25rem; padding: 1rem; border: 1px solid var(--border-color); border-radius: 8px; }
  .role-fieldset legend { padding: 0 0.5rem; color: var(--text-secondary); font-size: 0.9rem; }
  .radio-label { display: flex; align-items: center; gap: 0.5rem; margin-top: 0.5rem; cursor: pointer; color: var(--text-primary); }
  .register-form button {
    margin-top: 1.25rem; padding: 0.6rem 1.2rem; font-size: 1rem; font-weight: 600; border: none; border-radius: 6px;
    background: linear-gradient(135deg, var(--accent-teal), var(--accent-cyan)); color: var(--bg-primary); cursor: pointer;
  }
  .register-form button:hover:not(:disabled) { opacity: 0.9; }
  .register-form button:disabled { opacity: 0.6; cursor: not-allowed; }
  .form-message { margin-top: 1rem; min-height: 1.5em; font-size: 0.95rem; }
  .section { margin-top: 2rem; }
</style>
