---
/**
 * Boing Design Kit — FeatureGrid
 * Renders a grid of Cards from a features array. columns: 2 | 3 | 4
 */
import Card from './Card.astro';

interface Feature {
  title: string;
  description: string;
}

interface Props {
  features: Feature[];
  columns?: 2 | 3 | 4;
  className?: string;
}

const { features, columns = 3, className = '' } = Astro.props;

const gridClass = {
  2: 'grid-cols-1 md:grid-cols-2',
  3: 'grid-cols-1 md:grid-cols-3',
  4: 'grid-cols-1 md:grid-cols-2 lg:grid-cols-4',
}[columns];
---
<div class={`grid ${gridClass} gap-6 w-full ${className}`.trim()}>
  {features.map((feature) => (
    <Card title={feature.title} description={feature.description} />
  ))}
</div>
