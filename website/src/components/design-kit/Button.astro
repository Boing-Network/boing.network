---
/**
 * Boing Design Kit — Button
 * Variants: primary | secondary | ghost. Sizes: sm | md | lg.
 */
interface Props {
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  disabled?: boolean;
  type?: 'button' | 'submit' | 'reset';
  href?: string;
  className?: string;
}

const { variant = 'primary', size = 'md', disabled = false, type = 'button', href, className = '' } = Astro.props;

const base = 'font-display font-semibold rounded-md transition-all duration-200 cursor-pointer inline-block text-center no-underline';
const variants = {
  primary: 'bg-neon-cyan text-ocean-blue shadow-glow-cyan hover:shadow-glow-cyan-lg hover:-translate-y-0.5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-neon-cyan focus-visible:outline-offset-2',
  secondary: 'bg-transparent text-electric-blue border-2 border-electric-blue hover:bg-electric-blue hover:text-soft-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-electric-blue focus-visible:outline-offset-2',
  ghost: 'bg-transparent text-neon-cyan hover:underline hover:shadow-glow-cyan focus-visible:outline focus-visible:outline-2 focus-visible:outline-neon-cyan focus-visible:outline-offset-2',
};
const sizes = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3 text-base',
  lg: 'px-8 py-4 text-lg',
};
const disabledClass = disabled ? 'opacity-50 cursor-not-allowed pointer-events-none' : '';
const cls = `${base} ${variants[variant]} ${sizes[size]} ${disabledClass} ${className}`.trim();
---
{href ? (
  <a href={href} class={cls} aria-disabled={disabled || undefined}>
    <slot />
  </a>
) : (
  <button type={type} class={cls} disabled={disabled}>
    <slot />
  </button>
)}
