---
/**
 * Boing Design Kit — GlowingText
 * intensity: low | medium | high. color: cyan | blue | green
 */
interface Props {
  intensity?: 'low' | 'medium' | 'high';
  color?: 'cyan' | 'blue' | 'green';
  as?: 'span' | 'strong' | 'em';
  className?: string;
}

const { intensity = 'medium', color = 'cyan', as: Tag = 'span', className = '' } = Astro.props;

const glowMap: Record<string, Record<string, string>> = {
  cyan: {
    low: 'text-neon-cyan shadow-glow-cyan',
    medium: 'text-neon-cyan shadow-glow-cyan-lg',
    high: 'text-neon-cyan shadow-glow-cyan-lg animate-glow-pulse',
  },
  blue: {
    low: 'text-electric-blue shadow-glow-blue',
    medium: 'text-electric-blue shadow-glow-blue-lg',
    high: 'text-electric-blue shadow-glow-blue-lg animate-glow-pulse',
  },
  green: {
    low: 'text-bio-green',
    medium: 'text-bio-green',
    high: 'text-bio-green animate-glow-pulse',
  },
};
const cls = `${glowMap[color][intensity]} transition-all duration-300 ${className}`.trim();
---
<Tag class={cls}>
  <slot />
</Tag>
