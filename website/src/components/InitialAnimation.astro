---
/**
 * Full-viewport initial animation for the homepage.
 * Aquatic + cosmic elements orbit the Boing mascot; theme-aligned (Cosmic Foundation).
 * Respects prefers-reduced-motion. Dismisses on click/scroll or after delay.
 */
interface Props {
  /** Duration in ms before auto-dismiss (0 = no auto). */
  autoDismissMs?: number;
}

const { autoDismissMs = 4800 } = Astro.props;
---

<div class="intro-overlay" id="intro-overlay" aria-hidden="true" data-auto-dismiss={autoDismissMs}>
  <div class="intro-backdrop"></div>
  <div class="intro-vignette" aria-hidden="true"></div>

  <div class="intro-scene" id="intro-scene">
    <div class="intro-orbit-container">
      <!-- Inner orbit: 3D bubbles + stars (closer in Z) -->
      <div class="orbit orbit-inner" style="--orbit-duration: 18s; --orbit-radius: clamp(140px, 28vw, 220px); --orbit-z: 60px; --orbit-tilt: 8deg;">
        <span class="orbit-item bubble" aria-hidden="true"></span>
        <span class="orbit-item star" aria-hidden="true"></span>
        <span class="orbit-item bubble" aria-hidden="true"></span>
        <span class="orbit-item star" aria-hidden="true"></span>
        <span class="orbit-item bubble" aria-hidden="true"></span>
        <span class="orbit-item star" aria-hidden="true"></span>
      </div>

    <!-- Mid orbit: jellyfish + orbs (mid depth, tilted) -->
    <div class="orbit orbit-mid" style="--orbit-duration: 28s; --orbit-radius: clamp(200px, 40vw, 320px); --orbit-z: 0px; --orbit-tilt: -6deg;">
        <span class="orbit-item jellyfish" aria-hidden="true"></span>
        <span class="orbit-item orb-cyan" aria-hidden="true"></span>
        <span class="orbit-item jellyfish" aria-hidden="true"></span>
        <span class="orbit-item orb-violet" aria-hidden="true"></span>
        <span class="orbit-item jellyfish" aria-hidden="true"></span>
        <span class="orbit-item orb-cyan" aria-hidden="true"></span>
        <span class="orbit-item coral" aria-hidden="true"></span>
        <span class="orbit-item orb-violet" aria-hidden="true"></span>
      </div>

      <!-- Outer orbit: ring + planets (further in Z) -->
      <div class="orbit orbit-outer" style="--orbit-duration: 42s; --orbit-radius: clamp(280px, 55vw, 440px); --orbit-z: -80px; --orbit-tilt: 10deg;">
        <span class="orbit-item ring" aria-hidden="true"></span>
        <span class="orbit-item planet" aria-hidden="true"></span>
        <span class="orbit-item planet-small" aria-hidden="true"></span>
        <span class="orbit-item star-bright" aria-hidden="true"></span>
        <span class="orbit-item planet" aria-hidden="true"></span>
        <span class="orbit-item star-bright" aria-hidden="true"></span>
        <span class="orbit-item planet-small" aria-hidden="true"></span>
      </div>

      <!-- 3D decorative ring (tilted, pulse) -->
      <div class="intro-ring-pulse" aria-hidden="true"></div>
    </div>

    <div class="intro-mascot-wrap">
      <div class="intro-mascot-3d">
        <img
          src="/assets/mascot-excited.png"
          alt=""
          class="intro-mascot-img"
          width="320"
          height="320"
        />
      </div>
    </div>
  </div>

  <p class="intro-hint">Scroll or tap to continue</p>
</div>

<script>
  (function () {
    const overlay = document.getElementById('intro-overlay');
    if (!overlay) return;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const autoDismissMs = parseInt(overlay.dataset.autoDismiss || '4800', 10);
    const OUTRO_SCENE_MS = 1200;  /* scene pull-away duration before overlay fade */
    const OUTRO_FADE_MS = 1000;   /* overlay fade duration */

    function dismiss() {
      window.removeEventListener('click', dismiss);
      window.removeEventListener('scroll', dismiss, { passive: true });
      window.removeEventListener('keydown', onKey);

      overlay.classList.add('intro-exiting');
      overlay.setAttribute('aria-hidden', 'true');

      setTimeout(function () {
        overlay.classList.add('intro-done');
        document.documentElement.classList.add('intro-complete');
      }, prefersReducedMotion ? 400 : OUTRO_SCENE_MS);
    }

    function onKey(e) {
      if (e.key === 'Enter' || e.key === ' ' || e.key === 'Escape') {
        e.preventDefault();
        dismiss();
      }
    }

    window.addEventListener('click', dismiss, { once: true });
    window.addEventListener('scroll', dismiss, { passive: true, once: true });
    window.addEventListener('keydown', onKey, { once: true });

    if (!prefersReducedMotion && autoDismissMs > 0) {
      setTimeout(dismiss, autoDismissMs);
    }
  })();
</script>

<style>
  .intro-overlay {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: 25;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: auto;
    opacity: 1;
    visibility: visible;
    transition:
      opacity 1s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      visibility 1s step-end;
  }

  .intro-overlay.intro-done {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition:
      opacity 1s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      visibility 1s step-end 1s;
  }

  .intro-backdrop {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 120% 120% at 50% 50%,
      rgba(2, 4, 8, 0.97) 0%,
      var(--boing-black, #020408) 50%,
      var(--boing-void, #050810) 100%
    );
    z-index: 0;
    opacity: 0;
    animation: intro-backdrop-in 1.4s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @keyframes intro-backdrop-in {
    to { opacity: 1; }
  }

  .intro-exiting .intro-backdrop {
    animation: none;
    transition: opacity 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .intro-exiting .intro-backdrop {
    opacity: 0.4;
  }

  .intro-vignette {
    position: absolute;
    inset: 0;
    z-index: 0.5;
    pointer-events: none;
    background: radial-gradient(
      ellipse 80% 80% at 50% 50%,
      transparent 40%,
      rgba(0, 0, 0, 0.35) 100%
    );
    opacity: 0;
    animation: intro-vignette-in 1.8s cubic-bezier(0.22, 1, 0.36, 1) 0.3s forwards;
  }

  @keyframes intro-vignette-in {
    to { opacity: 1; }
  }

  .intro-exiting .intro-vignette {
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .intro-scene {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
    perspective: 1400px;
    transform-style: preserve-3d;
    opacity: 1;
    transform: scale(1) translateZ(0);
    transition:
      opacity 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .intro-exiting .intro-scene {
    opacity: 0;
    transform: scale(0.96) translateZ(-120px);
  }

  .intro-orbit-container {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transform-style: preserve-3d;
    perspective: 1400px;
  }

  .orbit {
    position: absolute;
    width: calc(2 * var(--orbit-radius, 200px));
    height: calc(2 * var(--orbit-radius, 200px));
    transform-style: preserve-3d;
    transform: translateZ(var(--orbit-z, 0)) rotateX(var(--orbit-tilt, 0));
    animation: orbit-spin var(--orbit-duration) linear infinite;
    opacity: 0;
  }

  .orbit-inner {
    --orbit-radius: clamp(140px, 28vw, 220px);
    --orbit-z: 60px;
    --orbit-tilt: 8deg;
    animation: orbit-spin 18s linear infinite, orbit-fade-in 1s cubic-bezier(0.22, 1, 0.36, 1) 0.5s forwards;
  }
  .orbit-mid {
    --orbit-radius: clamp(200px, 40vw, 320px);
    --orbit-z: 0px;
    --orbit-tilt: -6deg;
    animation: orbit-spin 28s linear infinite reverse, orbit-fade-in 1s cubic-bezier(0.22, 1, 0.36, 1) 0.7s forwards;
  }
  .orbit-outer {
    --orbit-radius: clamp(280px, 55vw, 440px);
    --orbit-z: -80px;
    --orbit-tilt: 10deg;
    animation: orbit-spin 42s linear infinite, orbit-fade-in 1.1s cubic-bezier(0.22, 1, 0.36, 1) 0.9s forwards;
  }

  @keyframes orbit-spin {
    from { transform: translateZ(var(--orbit-z, 0)) rotateX(var(--orbit-tilt, 0)) rotate(0deg); }
    to   { transform: translateZ(var(--orbit-z, 0)) rotateX(var(--orbit-tilt, 0)) rotate(360deg); }
  }

  @keyframes orbit-fade-in {
    to { opacity: 1; }
  }

  .intro-exiting .orbit {
    opacity: 0;
    transition: opacity 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .orbit-item {
    position: absolute;
    display: block;
    top: 50%;
    left: 50%;
    transform-origin: center center;
    transform-style: preserve-3d;
  }

  /* Place items around the circle: 0deg = right, 90deg = bottom */
  .orbit-inner .orbit-item:nth-child(1) { transform: translate(-50%, -50%) rotate(0deg)   translateX(var(--orbit-radius)) rotate(-0deg);   }
  .orbit-inner .orbit-item:nth-child(2) { transform: translate(-50%, -50%) rotate(60deg)  translateX(var(--orbit-radius)) rotate(-60deg);  }
  .orbit-inner .orbit-item:nth-child(3) { transform: translate(-50%, -50%) rotate(120deg) translateX(var(--orbit-radius)) rotate(-120deg); }
  .orbit-inner .orbit-item:nth-child(4) { transform: translate(-50%, -50%) rotate(180deg) translateX(var(--orbit-radius)) rotate(-180deg); }
  .orbit-inner .orbit-item:nth-child(5) { transform: translate(-50%, -50%) rotate(240deg) translateX(var(--orbit-radius)) rotate(-240deg); }
  .orbit-inner .orbit-item:nth-child(6) { transform: translate(-50%, -50%) rotate(300deg) translateX(var(--orbit-radius)) rotate(-300deg); }

  .orbit-mid .orbit-item:nth-child(1) { transform: translate(-50%, -50%) rotate(0deg)    translateX(var(--orbit-radius)) rotate(-0deg);    }
  .orbit-mid .orbit-item:nth-child(2) { transform: translate(-50%, -50%) rotate(45deg)   translateX(var(--orbit-radius)) rotate(-45deg);   }
  .orbit-mid .orbit-item:nth-child(3) { transform: translate(-50%, -50%) rotate(90deg)   translateX(var(--orbit-radius)) rotate(-90deg);   }
  .orbit-mid .orbit-item:nth-child(4) { transform: translate(-50%, -50%) rotate(135deg)  translateX(var(--orbit-radius)) rotate(-135deg);  }
  .orbit-mid .orbit-item:nth-child(5) { transform: translate(-50%, -50%) rotate(180deg)  translateX(var(--orbit-radius)) rotate(-180deg);  }
  .orbit-mid .orbit-item:nth-child(6) { transform: translate(-50%, -50%) rotate(225deg)  translateX(var(--orbit-radius)) rotate(-225deg);  }
  .orbit-mid .orbit-item:nth-child(7) { transform: translate(-50%, -50%) rotate(270deg)  translateX(var(--orbit-radius)) rotate(-270deg);  }
  .orbit-mid .orbit-item:nth-child(8) { transform: translate(-50%, -50%) rotate(315deg)  translateX(var(--orbit-radius)) rotate(-315deg);  }

  .orbit-outer .orbit-item:nth-child(1) { transform: translate(-50%, -50%) rotate(0deg)   translateX(var(--orbit-radius)) rotate(-0deg);   }
  .orbit-outer .orbit-item:nth-child(2) { transform: translate(-50%, -50%) rotate(51deg)  translateX(var(--orbit-radius)) rotate(-51deg);  }
  .orbit-outer .orbit-item:nth-child(3) { transform: translate(-50%, -50%) rotate(102deg) translateX(var(--orbit-radius)) rotate(-102deg); }
  .orbit-outer .orbit-item:nth-child(4) { transform: translate(-50%, -50%) rotate(153deg) translateX(var(--orbit-radius)) rotate(-153deg); }
  .orbit-outer .orbit-item:nth-child(5) { transform: translate(-50%, -50%) rotate(204deg) translateX(var(--orbit-radius)) rotate(-204deg); }
  .orbit-outer .orbit-item:nth-child(6) { transform: translate(-50%, -50%) rotate(255deg) translateX(var(--orbit-radius)) rotate(-255deg); }
  .orbit-outer .orbit-item:nth-child(7) { transform: translate(-50%, -50%) rotate(306deg) translateX(var(--orbit-radius)) rotate(-306deg); }

  /* Aquatic: 3D bubble (sphere highlight) */
  .orbit-item.bubble {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: radial-gradient(circle at 28% 28%, rgba(255,255,255,0.9), rgba(255,255,255,0.3) 40%, var(--network-cyan) 70%, var(--network-cyan) 100%);
    box-shadow:
      0 0 14px var(--network-cyan-glow),
      inset -2px -2px 4px rgba(0,0,0,0.2),
      inset 2px 2px 4px rgba(255,255,255,0.3);
    opacity: 0.9;
    transform-style: preserve-3d;
  }

  /* Cosmic: star (bright point) */
  .orbit-item.star,
  .orbit-item.star-bright {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, #fff, rgba(255,255,255,0.85) 50%, rgba(255,255,255,0.4));
    box-shadow: 0 0 10px rgba(255,255,255,0.9), 0 0 20px rgba(255,255,255,0.4);
    opacity: 0.95;
  }
  .orbit-item.star-bright {
    width: 10px;
    height: 10px;
    box-shadow: 0 0 14px var(--network-cyan-light), 0 0 8px #fff, inset 0 0 6px rgba(255,255,255,0.5);
  }

  /* Jellyfish blob (3D soft sphere) */
  .orbit-item.jellyfish {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, var(--network-cyan-light), var(--network-cyan) 45%, var(--network-primary) 100%);
    filter: blur(1px);
    opacity: 0.65;
    box-shadow: 0 0 24px var(--network-cyan-glow), inset 2px 2px 6px rgba(255,255,255,0.15);
  }

  /* 3D orbs (sphere gradient + inner shadow) */
  .orbit-item.orb-cyan {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: radial-gradient(circle at 32% 28%, var(--network-cyan-light), var(--network-cyan) 50%, #0a7a8a 100%);
    box-shadow: 0 0 18px var(--network-cyan-glow), inset -3px -3px 6px rgba(0,0,0,0.25), inset 2px 2px 4px rgba(255,255,255,0.2);
    opacity: 0.85;
  }
  .orbit-item.orb-violet {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: radial-gradient(circle at 32% 28%, var(--network-primary-light), var(--network-primary) 50%, #5b21b6 100%);
    box-shadow: 0 0 18px var(--network-primary-glow), inset -3px -3px 6px rgba(0,0,0,0.25), inset 2px 2px 4px rgba(255,255,255,0.15);
    opacity: 0.85;
  }

  /* Coral (tiny 3D-ish branch) */
  .orbit-item.coral {
    width: 14px;
    height: 14px;
    border-radius: 3px;
    background: linear-gradient(145deg, var(--network-nebula) 0%, var(--network-primary) 50%, #5b21b6 100%);
    box-shadow: inset 1px 1px 2px rgba(255,255,255,0.1);
    opacity: 0.55;
  }

  /* Ring (tilted 3D trace) */
  .orbit-item.ring {
    width: 22px;
    height: 22px;
    border: 2px solid rgba(124, 58, 237, 0.5);
    border-radius: 50%;
    background: transparent;
    opacity: 0.75;
    box-shadow: 0 0 12px rgba(124, 58, 237, 0.2);
  }

  /* 3D planets (sphere gradient) */
  .orbit-item.planet {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 25%, var(--network-primary-light), var(--network-primary) 45%, #4c1d95 100%);
    box-shadow: 0 0 12px var(--network-primary-glow), inset -2px -2px 4px rgba(0,0,0,0.3), inset 1px 1px 3px rgba(255,255,255,0.15);
    opacity: 0.9;
  }
  .orbit-item.planet-small {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 30%, var(--network-cyan-light), var(--network-cyan) 60%, #0e7490 100%);
    box-shadow: 0 0 10px var(--network-cyan-glow), inset -1px -1px 3px rgba(0,0,0,0.2);
    opacity: 0.85;
  }

  .intro-ring-pulse {
    position: absolute;
    width: clamp(180px, 35vw, 280px);
    height: clamp(180px, 35vw, 280px);
    border-radius: 50%;
    border: 1px solid rgba(124, 58, 237, 0.25);
    transform: rotateX(12deg);
    transform-style: preserve-3d;
    pointer-events: none;
    opacity: 0;
    animation: orbit-fade-in 1s cubic-bezier(0.22, 1, 0.36, 1) 1s forwards, ring-pulse 3.5s ease-in-out 2s infinite;
  }

  @keyframes ring-pulse {
    0%, 100% { opacity: 0.35; transform: rotateX(12deg) scale(1); }
    50%      { opacity: 0.75; transform: rotateX(12deg) scale(1.03); }
  }

  .intro-mascot-wrap {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: clamp(200px, 45vw, 320px);
    height: clamp(200px, 45vw, 320px);
    transform-style: preserve-3d;
    opacity: 0;
    animation: mascot-appear 1.6s cubic-bezier(0.16, 1, 0.3, 1) 0.9s forwards;
    filter: drop-shadow(0 0 40px var(--network-primary-glow)) drop-shadow(0 0 60px var(--network-cyan-glow));
    transition: opacity 1s cubic-bezier(0.25, 0.46, 0.45, 0.94), transform 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .intro-exiting .intro-mascot-wrap {
    opacity: 0;
    transform: scale(0.92) translateZ(-60px);
  }

  .intro-mascot-3d {
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transform: rotateX(-4deg) rotateY(2deg);
    animation: mascot-3d-float 8s ease-in-out infinite;
  }

  .intro-mascot-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    animation: mascot-glow 4.5s ease-in-out infinite;
  }

  @keyframes mascot-appear {
    0%   { opacity: 0; transform: scale(0.88) translateZ(-80px); }
    100% { opacity: 1; transform: scale(1) translateZ(0); }
  }

  @keyframes mascot-3d-float {
    0%, 100% { transform: rotateX(-4deg) rotateY(2deg) translateY(0); }
    50%      { transform: rotateX(-5deg) rotateY(3deg) translateY(-10px); }
  }

  @keyframes mascot-glow {
    0%, 100% { filter: drop-shadow(0 0 30px var(--network-primary-glow)); }
    50%      { filter: drop-shadow(0 0 50px var(--network-cyan-glow)); }
  }

  .intro-hint {
    position: absolute;
    bottom: clamp(1.5rem, 5vh, 3rem);
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    margin: 0;
    font-size: clamp(0.75rem, 2vw, 0.9rem);
    color: var(--text-secondary);
    letter-spacing: 0.08em;
    opacity: 0;
    animation: hint-fade 0.8s cubic-bezier(0.22, 1, 0.36, 1) 2.4s forwards;
    transition: opacity 0.5s ease;
  }

  .intro-exiting .intro-hint {
    opacity: 0;
  }

  @keyframes hint-fade {
    to { opacity: 0.7; }
  }

  @media (prefers-reduced-motion: reduce) {
    .intro-backdrop {
      animation: intro-backdrop-in 0.6s ease forwards;
    }
    .intro-vignette {
      animation: intro-vignette-in 0.5s ease 0.2s forwards;
    }
    .intro-scene {
      perspective: none;
    }
    .orbit {
      animation: none;
      transform: none;
      opacity: 0.85;
    }
    .orbit-inner,
    .orbit-mid,
    .orbit-outer {
      animation: none;
      opacity: 0.85;
    }
    .intro-mascot-wrap {
      animation: mascot-appear 0.7s ease 0.3s forwards;
    }
    .intro-mascot-3d {
      animation: none;
      transform: none;
    }
    .intro-mascot-img {
      animation: none;
    }
    .intro-ring-pulse {
      animation: none;
      opacity: 0.5;
      transform: none;
    }
    .intro-exiting .intro-scene {
      transition-duration: 0.5s;
    }
    .intro-exiting .intro-mascot-wrap {
      transition-duration: 0.5s;
    }
    .intro-hint {
      animation: hint-fade 0.5s ease 0.5s forwards;
    }
  }
</style>
