---
interface Props {
  hub: 'developer' | 'user' | 'operator';
  current: 'index' | 'dashboard' | 'resources' | 'quests' | 'leaderboard';
}
const { hub, current } = Astro.props;
const hubNames: Record<typeof hub, string> = {
  developer: 'Developer Hub',
  user: 'Community Hub',
  operator: 'Operator Hub',
};
const base: Record<typeof hub, string> = {
  developer: '/testnet/developers',
  user: '/testnet/users',
  operator: '/testnet/operators',
};

const navItems =
  hub === 'developer'
    ? [
        { slug: 'index' as const, label: 'Overview', href: base.developer },
        { slug: 'dashboard' as const, label: 'Dashboard', href: `${base.developer}/dashboard` },
        { slug: 'resources' as const, label: 'Resources', href: `${base.developer}/resources` },
      ]
    : hub === 'user'
      ? [
          { slug: 'index' as const, label: 'Overview', href: base.user },
          { slug: 'dashboard' as const, label: 'Dashboard', href: `${base.user}/dashboard` },
          { slug: 'quests' as const, label: 'Quests', href: `${base.user}/quests` },
        ]
      : [
          { slug: 'index' as const, label: 'Overview', href: base.operator },
          { slug: 'leaderboard' as const, label: 'Leaderboard', href: `${base.operator}/leaderboard` },
          { slug: 'resources' as const, label: 'Resources', href: `${base.operator}/resources` },
        ];
---

<nav class="hub-nav">
  <a href="/testnet">Portal</a>
  <span class="hub-name">{hubNames[hub]}</span>
  {navItems.map((item) => (
    <a href={item.href} class:list={[current === item.slug && 'active']}>{item.label}</a>
  ))}
  <span id="portal-auth" class="hub-auth"></span>
</nav>

<style>
  .hub-nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 1rem;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
  }
  .hub-nav a {
    color: var(--text-secondary);
    font-weight: 500;
    text-decoration: none;
    transition: color var(--motion-links-transition_duration, 0.25s) ease-out;
  }
  .hub-nav a:hover {
    color: var(--accent-teal);
  }
  .hub-nav a.active {
    color: var(--accent-teal);
    font-weight: 600;
  }
  .hub-nav a:focus-visible {
    outline: 2px solid var(--accent-teal);
    outline-offset: 2px;
    border-radius: 4px;
  }
  .hub-name {
    color: var(--accent-teal);
    font-weight: 600;
  }
  .hub-auth {
    margin-left: auto;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }
  .hub-auth .account-short {
    font-family: var(--font-mono);
    color: var(--accent-teal);
  }
  .hub-auth a {
    color: var(--accent-teal);
    transition: color 0.2s ease;
  }
  .hub-auth a:focus-visible {
    outline: 2px solid var(--accent-teal);
    outline-offset: 2px;
    border-radius: 4px;
  }
  .auth-signout {
    background: none;
    border: none;
    color: var(--text-tertiary);
    cursor: pointer;
    font-size: inherit;
    padding: 0;
    transition: color 0.2s ease;
  }
  .auth-signout:hover {
    color: var(--accent-teal);
  }
  .auth-signout:focus-visible {
    outline: 2px solid var(--accent-teal);
    outline-offset: 2px;
    border-radius: 4px;
  }
</style>
