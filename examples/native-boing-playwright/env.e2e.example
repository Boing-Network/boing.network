# Copy to .env.e2e (gitignored) and `set -a && source .env.e2e` before npm run test:e2e — or export manually.
# CI / self-hosted patterns: ../../docs/PLAYWRIGHT-E2E-CI-OPS.md

# Absolute path to unpacked Boing Express (directory containing manifest.json).
# Windows (Git Bash): export BOING_EXPRESS_EXTENSION_PATH="/c/Users/you/AppData/Local/Google/Chrome/User Data/Default/Extensions/<id>/<version>"
# Or unzip a CI/store build to a folder and point here.
BOING_EXPRESS_EXTENSION_PATH=

# Public page to open first (default https://boing.finance/swap). CI often uses https://boing.network/
# because headless/datacenter IPs may get 403 on the finance app; the smoke test then tries fallbacks.
# BOING_E2E_SWAP_URL=https://boing.finance/swap
# Optional extra fallbacks (comma-separated), after env primary and before built-in boing.network URLs.
# BOING_E2E_SWAP_FALLBACK_URLS=https://www.boing.network/

# How long to wait for [data-testid="native-amm-panel"] after load (unlock + connect Boing Express on testnet 6913).
# BOING_E2E_PANEL_TIMEOUT_MS=120000

# Set to 1 to open Playwright inspector pause after navigation (manual connect/unlock).
# BOING_E2E_PAUSE=0
